/share/Configuration/apache/logs/*.log {
  daily
  missingok
  rotate 7
  compress
  delaycompress
  notifempty
  create 640 as-www-data root
  sharedscripts
  postrotate
    if pgrep -f ^/usr/local/AppCentral/cappysan-apache/bin/apache2 > /dev/null; then
      /usr/local/AppCentral/cappysan-apache/CONTROL/start-stop.sh reload
    fi
  endscript
}
